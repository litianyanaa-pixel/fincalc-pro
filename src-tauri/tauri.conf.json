{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "FinCalc Pro",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": true }
    },
    "bundle": {
      "active": true,
      "category": "Finance",
      "copyright": "Copyright 2026 FinCalc Pro",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.fincalc.pro",
      "longDescription": "FinCalc Pro - Professional Investment Return Analysis Workstation",
      "resources": ["WebView2Loader.dll"],
      "shortDescription": "Investment Return Calculator",
      "targets": ["msi", "nsis"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "webviewInstallMode": {
          "type": "embedBootstrapper",
          "silent": true
        },
        "nsis": {
          "installMode": "currentUser",
          "languages": ["SimpChinese", "English"],
          "displayLanguageSelector": true
        }
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "width": 1024,
        "height": 680,
        "minWidth": 640,
        "minHeight": 480,
        "maximized": true,
        "resizable": true,
        "title": "FinCalc Pro",
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ]
  }
}
